# Per-task ignores. Follow this shape for new tasks.

# Downloaded source data (regenerated by build.py).
_data/

# Bundle contents that ship to the agent — regenerated by build.py.
# We keep the directory in git for structure but skip the large binaries.
bundle/*.parquet
bundle/*.npz
bundle/*.pkl

# Hidden ground truth — must not ship, and by policy stays out of git too.
# If you want a task's answer key committed (e.g. because it's public
# labels re-derived from a public source), delete this line.
hidden/

# Agent-run artifacts: keep grade.json / run_summary.json / method.md /
# training_manifest.json. Skip the parquet answer + agent log tail + heavy
# intermediates.
runs/**/*.parquet
runs/**/*.npz
runs/**/*.pkl
runs/**/agent_log.jsonl
runs/**/agent_stderr.txt
runs/**/feats_*
runs/**/preds_*
runs/**/checkpoint/
